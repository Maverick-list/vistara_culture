{
  "routes": [
    { "route": "/api/*", "allowedRoles": ["anonymous"] },
    { "route": "/_next/static/*", "headers": { "Cache-Control": "public, max-age=31536000, immutable" } },
    { "route": "/*", "serve": "/index.html", "statusCode": 200 }
  ],
  "navigationFallback": { "rewrite": "/index.html", "exclude": ["/_next/static/*", "/api/*"] },
  "responseOverrides": { "404": { "rewrite": "/404", "statusCode": 404 } },
  "globalHeaders": {
    "X-Frame-Options": "SAMEORIGIN",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "platform": { "apiRuntime": "node:18" }
}
